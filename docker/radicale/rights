[allow-discovery-root]
user: .+
collection:
permissions: R

[allow-user-principal]
user: .+
collection: {user}
permissions: RW

[allow-user-calendars]
user: .+
collection: {user}/[^/]+
permissions: RWrw

[allow-team-principal]
user: .+
collection: team
permissions: R

[allow-team-calendars]
user: .+
collection: team/[^/]+
permissions: RWrw
